# ============================================================================
# Smart Routing Configuration (เลือกใช้ตามลำดับความสำคัญ)
# ลำดับ: 1. Local OpenClaw -> 2. Tailscale OpenClaw -> 3. Direct MiniMax
# ============================================================================

# ----------------------------------------------------------------------------
# [1] OpenClaw Gateway Settings (Primary & Secondary)
# ----------------------------------------------------------------------------
OPENCLAW_TOKEN=your_openclaw_token
OPENCLAW_LOCAL_URL=http://127.0.0.1:1111/v1/chat/completions
OPENCLAW_TS_URL=http://100.69.181.45:1111/v1/chat/completions
OPENCLAW_MODEL=minimax/MiniMax-M2.7

# ----------------------------------------------------------------------------
# [2] MiniMax Direct Settings (Fallback หาก OpenClaw ปิดอยู่)
# ----------------------------------------------------------------------------
MINIMAX_API_KEY=your_minimax_direct_key_if_any
MINIMAX_BASE_URL=https://api.minimax.chat/v1/chat/completions
MINIMAX_MODEL=MiniMax-Text-01

# ----------------------------------------------------------------------------
# Connection Configuration
# ----------------------------------------------------------------------------
MINIMAX_API_TIMEOUT=60
MINIMAX_CONNECTION_TIMEOUT=10